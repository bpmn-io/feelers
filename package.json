{
  "name": "feelers",
  "version": "1.5.1",
  "description": "FEELers templating language - parser (Lezer), interpreter and editor (CodeMirror).",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "all": "run-s build lint test",
    "test": "karma start karma.conf.cjs",
    "generate:parser": "lezer-generator src/grammar/feelers.grammar -o src/grammar/parser.js",
    "bundle": "rollup -c",
    "dev": "npm test -- --auto-watch --no-single-run",
    "build": "npm run generate:parser && npm run bundle",
    "lint": "eslint .",
    "start": "cross-env SINGLE_START=true npm run dev",
    "prepare": "run-s build"
  },
  "author": {
    "name": "Valentin Serra",
    "url": "https://github.com/skaiir"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": "*"
  },
  "keywords": [
    "FEEL",
    "FEELers",
    "Lezer",
    "Grammer",
    "Parser"
  ],
  "files": [
    "dist"
  ],
  "license": "MIT",
  "dependencies": {
    "@bpmn-io/cm-theme": "^0.1.0-alpha.2",
    "@bpmn-io/feel-lint": "^3.1.0",
    "@bpmn-io/feelin": "^6.1.0",
    "@bpmn-io/lezer-feel": "^3.0.0",
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.1",
    "@codemirror/language": "^6.12.1",
    "@codemirror/lint": "^6.9.3",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.12",
    "@lezer/common": "^1.5.1",
    "@lezer/highlight": "^1.1.6",
    "@lezer/lr": "^1.4.8",
    "@lezer/markdown": "^1.6.3",
    "min-dom": "^5.2.0",
    "mitt": "^3.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.23.2",
    "@babel/preset-env": "^7.23.2",
    "@lezer/generator": "^1.8.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@types/chai": "^5.0.0",
    "@types/mocha": "^10.0.10",
    "chai": "^6.0.0",
    "cross-env": "^10.0.0",
    "eslint": "^9.39.2",
    "eslint-plugin-bpmn-io": "^2.3.1",
    "karma": "^6.4.4",
    "karma-chrome-launcher-2": "^3.3.0",
    "karma-debug-launcher": "^0.0.5",
    "karma-env-preprocessor": "^0.1.1",
    "karma-firefox-launcher": "^2.1.3",
    "karma-mocha": "^2.0.1",
    "karma-tldr-reporter": "^0.0.1",
    "karma-webpack": "^5.0.1",
    "marked": "^18.0.5",
    "mocha": "^11.7.6",
    "mocha-test-container-support": "^0.2.0",
    "npm-run-all2": "^9.0.0",
    "rollup": "^4.22.4",
    "sinon": "^22.0.0",
    "sinon-chai": "^4.0.0",
    "typescript": "^6.0.0"
  }
}
