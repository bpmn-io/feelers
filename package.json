{
  "name": "feelers-builder",
  "version": "0.0.0",
  "description": "FEELers monorepo - builds and validates all packages.",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/lezer-feelers",
    "packages/feelers",
    "packages/lang-feelers",
    "packages/feelers-lint",
    "packages/feelers-editor"
  ],
  "scripts": {
    "all": "npm run all --workspaces",
    "start": "npm run start -w @bpmn-io/feelers-editor",
    "dev": "npm run dev -w @bpmn-io/feelers-editor",
    "publish": "node tasks/publish.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bpmn-io/feelers.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/chai": "^5.0.0",
    "@types/mocha": "^10.0.10",
    "bio-dts": "^0.15.3",
    "chai": "^6.0.0",
    "eslint": "^9.39.2",
    "eslint-plugin-bpmn-io": "^2.3.1",
    "karma": "^6.4.4",
    "karma-chrome-launcher-2": "^3.3.0",
    "karma-debug-launcher": "^0.0.5",
    "karma-env-preprocessor": "^0.1.1",
    "karma-mocha": "^2.0.1",
    "karma-tldr-reporter": "^0.0.2",
    "karma-webpack": "^5.0.1",
    "mocha": "^11.7.6",
    "npm-run-all2": "^9.0.2",
    "sinon": "^22.0.0",
    "sinon-chai": "^4.0.0",
    "typescript": "^6.0.0"
  }
}
