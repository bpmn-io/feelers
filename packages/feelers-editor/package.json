{
  "name": "@bpmn-io/feelers-editor",
  "version": "1.0.0",
  "description": "FEELers editor component built on CodeMirror 6.",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "all": "run-s build lint test test:types",
    "build": "run-s generate:types",
    "generate:types": "bio-dts -r lib",
    "lint": "eslint .",
    "test": "karma start karma.conf.cjs",
    "test:types": "tsc --noEmit",
    "dev": "npm test -- --auto-watch --no-single-run",
    "start": "cross-env SINGLE_START=true npm run dev",
    "prepare": "run-s build"
  },
  "exports": {
    ".": "./lib/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "lib"
  ],
  "keywords": [
    "FEEL",
    "FEELers",
    "CodeMirror",
    "editor"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bpmn-io/feelers.git",
    "directory": "packages/feelers-editor"
  },
  "dependencies": {
    "@bpmn-io/feelers-lint": "^1.0.0",
    "@bpmn-io/lang-feelers": "^1.0.0",
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.1",
    "@codemirror/language": "^6.12.1",
    "@codemirror/lint": "^6.9.3",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.12",
    "@lezer/markdown": "^1.6.3",
    "min-dom": "^5.2.0",
    "mitt": "^3.0.1"
  },
  "devDependencies": {
    "@bpmn-io/cm-theme": "0.2.0",
    "cross-env": "^10.1.0",
    "marked": "^18.0.5",
    "mocha-test-container-support": "^0.2.0"
  },
  "peerDependencies": {
    "@bpmn-io/cm-theme": "^0.2.0"
  }
}
